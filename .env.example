# ─────────────────────────────────────────────────────────────────────────────
# Buyue — Environment Variables (example)
# Copy to .env.local and fill in per environment. NEVER commit real secrets.
# Values below are placeholders; the actual services are decided in later phases
# (audit C-02 backend, C-09 form/lead destination, H-10 analytics).
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL (used for metadataBase, canonical, sitemap, hreflang).
# TODO(C-08): confirm the canonical production domain (buyue.com vs buyue.sa).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (H-10) — vendor + key TBD; consent-gated.
NEXT_PUBLIC_ANALYTICS_ID=

# Contact form submission destination (Phase 8 / C-09) — endpoint + provider TBD.
CONTACT_FORM_ENDPOINT=

# Admin / CMS backend (Phase 9 / C-02) — connection details TBD.
# ADMIN_API_URL=
# ADMIN_API_TOKEN=
