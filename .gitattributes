# Normalise line endings.
#
# Without this, Windows clones (core.autocrlf=true) check text files out with
# CRLF while Prettier expects LF, so `npm run format:check` fails on every file
# in the repo regardless of its actual formatting.
#
# `text=auto eol=lf` stores LF in the repository AND checks LF out into the
# working tree on every platform, overriding autocrlf. Editors handle LF fine
# on Windows; .editorconfig already declares end_of_line = lf.
* text=auto eol=lf

# Binary assets — never touch these. Listed explicitly rather than relying on
# git's content heuristic, so a mis-detected file can't be corrupted.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.avif  binary
*.webp  binary
*.svgz  binary
*.pdf   binary
*.xlsx  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary

# Keep generated lockfiles out of diffs and merge conflicts.
package-lock.json -diff linguist-generated

# Mark documentation and vendored assets so language stats reflect the app.
docs/**         linguist-documentation
brand-assets/** linguist-vendored
